@page "/settings"
@using Portfolio.App.Models

@inject IAppSettingsService SettingsService
@inject Portfolio.App.Services.ThemeService ThemeService

<div class="settings-container">
    <MudPaper Class="@($"settings-card pa-6 {_themeClass}")">
        <MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

        <MudForm @ref="_form">

            <MudTextField @bind-Value="_settings.GitHubUsername"
                          Label="GitHub Username"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_settings.ContactEmail"
                          Label="Contact Email"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_settings.ContactPhone"
                          Label="Phone"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_settings.ContactLinkedIn"
                          Label="LinkedIn URL"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_settings.EmailSubjectTemplate"
                          Label="Email Subject"
                          Variant="Variant.Outlined"
                          Lines="2"
                          Class="mb-3" />

            <MudNumericField T="int"
                             @bind-Value="_settings.CacheDurationHours"
                             Label="Cache Duration (hours)"
                             Min="1"
                             Max="48"
                             Variant="Variant.Outlined"
                             Class="mb-4" />

            <div class="settings-btn-row">

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="Save">
                    Save
                </MudButton>

                <MudButton Color="Color.Secondary"
                           Variant="Variant.Outlined"
                           OnClick="Reset">
                    Reset
                </MudButton>

            </div>

        </MudForm>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudText Class="mt-3" Color="@_messageColor">
                @_message
            </MudText>
        }

    </MudPaper>
</div>

@code {
    private MudForm? _form;

    private AppSettings _settings = new();

    private string _themeClass = "light-theme";

    private string? _message;
    private Color _messageColor = Color.Success;

    protected override async Task OnInitializedAsync()
    {
        ThemeService.OnThemeChanged += OnThemeChanged;
        _themeClass = ThemeService.CurrentTheme + "-theme";

        _settings = await SettingsService.GetAsync();
    }

    private void OnThemeChanged()
    {
        _themeClass = ThemeService.CurrentTheme + "-theme";
        StateHasChanged();
    }

    private async Task Save()
    {
        await _form!.Validate();

        if (!_form.IsValid)
        {
            _message = "Fix validation errors.";
            _messageColor = Color.Error;
            return;
        }

        await SettingsService.SaveAsync(_settings);

        _message = "Settings saved!";
        _messageColor = Color.Success;

        StateHasChanged();
    }

    private async Task Reset()
    {
        _settings = new AppSettings();
        await SettingsService.SaveAsync(_settings);

        _message = "Reset to defaults.";
        _messageColor = Color.Info;
    }
}
<style>

    .settings-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: start;
        margin-top: 1rem;
        padding: 24px;
    }

    .page-container {
        min-height: 100vh;
    }

    .settings-card {
        width: 100%;
        max-width: 420px;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
        display: flex;
        flex-direction: column;
    }

    .settings-btn-row {
        display: flex;
        gap: 10px;
        width: 100%;
    }

        .settings-btn-row button {
            flex: 1;
        }
</style>