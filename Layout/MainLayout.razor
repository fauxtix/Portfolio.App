@using Blazored.LocalStorage
@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout Class="@_themeClass">

    <!-- TOP NAVBAR -->
    <MudAppBar Elevation="1" Fixed="true">

        <!-- Hamburger (mobile only) -->
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Class="d-md-none mr-2"
                       OnClick="ToggleDrawer"
                       Edge="Edge.Start"/>
        <!-- Brand/Logo -->
        <MudText Class="brand-text font-weight-bold ml-2 mr-6" OnClick="@(() => Nav.NavigateTo("/"))">
            <span style="vertical-align:middle;">🚀</span> GitHub Portfolio
        </MudText>

        <!-- Centered Navigation -->
        <div class="d-none d-md-flex flex-grow-1 nav-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Style="font-size:1.1rem;"
                       OnClick="@(() => Nav.NavigateTo("/"))">
                <span style="font-size:1.3rem;vertical-align:middle;">🗂️</span> <span class="ml-1">Repositories</span>
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Style="font-size:1.1rem;"
                       OnClick="@(() => Nav.NavigateTo("/issues-prs"))">
                <span style="font-size:1.3rem;vertical-align:middle;">🔀</span> <span class="ml-1">PRs & Issues</span>
            </MudButton>
        </div>

        <MudSpacer />

        <div class="navbar-actions">
            <MudIconButton Icon="@Icons.Material.Filled.Download"
                           Color="Color.Inherit"
                           OnClick="DownloadPdf"
                           Size="Size.Medium" />

            <!-- THEME TOGGLE -->
            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Size="Size.Medium"
                       OnClick="ToggleTheme">
                @_themeEmoji
            </MudButton>

            <!-- CLEAR CACHE -->
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           OnClick="ClearCache"
                           Size="Size.Medium" />

            <MudIconButton Icon="@Icons.Material.Filled.Settings"
                           Color="Color.Inherit"
                           OnClick="@(() => Nav.NavigateTo("/settings"))"
                           Size="Size.Medium" />

            @if (!_isLoggedIn)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@(() => Nav.NavigateTo("/login"))">
                    Login
                </MudButton>
            }

            @if (_isLoggedIn)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="Logout">
                    Logout
                </MudButton>
            }
        </div>

    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Anchor="Anchor.Left"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Temporary">

        <MudNavMenu Class="pt-4">

            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">
                Repositories
            </MudNavLink>

            <MudNavLink Href="/issues-prs"
                        Icon="@Icons.Material.Filled.Merge">
                PRs & Issues
            </MudNavLink>



            <MudNavLink Href="/settings"
                        Icon="@Icons.Material.Filled.Settings">
                Settings
            </MudNavLink>

        </MudNavMenu>

    </MudDrawer>

    <MudMainContent Style="padding-top:80px;" Class="@(_themeClass == "dark-theme" ? "dark-theme-bg" : "light-theme-bg")">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    [Inject] Portfolio.App.Services.ThemeService ThemeService { get; set; } = default!;
    [Inject] HttpClient? Http { get; set; } 
    [Inject] Portfolio.App.Services.AppState AppState { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] GitHubPdfService PdfService { get; set; } = default!;
    [Inject] IDialogService DialogService { get; set; } = default!;
    [Inject] GitHubPdfBuilderService PdfBuilder { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] ILocalStorageService LocalStorage { get; set; } = default!;
    [Inject] IConfiguration Configuration { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnLoginStateChanged { get; set; }

    private string _themeClass = "light-theme";

    private string _themeEmoji =>
        _themeClass == "dark-theme" ? "🌙" : "☀️";

    private bool _drawerOpen;

    private bool _loginDialogOpen = false;

    private string _pat = string.Empty;

    private string? _loginError;

    private string _username = string.Empty;

    private bool _isLoggedIn => AppState.IsLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        ThemeService.SetLocalStorage(LocalStorage);
        ThemeService.OnThemeChanged += OnThemeChanged;
        await ThemeService.LoadThemeAsync();
        _themeClass = ThemeService.CurrentTheme + "-theme";
        // Ensure username exists for PDF export
        var stored = await LocalStorage.GetItemAsStringAsync("github_username");
        if (!string.IsNullOrWhiteSpace(stored))
            _username = stored;
        else
            _username = Configuration["GitHub:DefaultUsername"] ?? "fauxtix";
        await base.OnInitializedAsync();
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async void OnThemeChanged()
    {
        _themeClass = ThemeService.CurrentTheme + "-theme";
        await JS.InvokeVoidAsync("applyDialogTheme", _themeClass);
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    private async Task ClearCache()
    {
        await LocalStorage.ClearAsync();

        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private void GoToPdfExport()
    {
        Nav.NavigateTo("/pdf-export");
    }

    private void OpenSettings()
    {
        Nav.NavigateTo("/settings");
    }

    private void OpenLoginDialog()
    {
        if (!_loginDialogOpen)
        {
            _loginDialogOpen = true;
            _loginError = null;
        }
    }

    private void CloseLoginDialog()
    {
        _loginDialogOpen = false;
        _pat = string.Empty;
        _loginError = null;
        StateHasChanged();
    }

    private async Task Login()
    {
        _loginError = null;

        try
        {

            Http!.DefaultRequestHeaders.UserAgent.ParseAdd("PortfolioApp");

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("token", _pat);

            var resp = await Http.GetAsync("https://api.github.com/user");

            if (!resp.IsSuccessStatusCode)
            {
                _loginError = "Invalid PAT or insufficient permissions.";

                StateHasChanged();

                return;
            }

            await LocalStorage.SetItemAsStringAsync("github_pat", _pat);

            AppState.SetLogin(_pat);

            CloseLoginDialog();
        }
        catch
        {
            _loginError = "Network or API error.";

            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("github_pat");

        AppState.SetLogout();
    }

    private void AppStateInit()
    {
        AppState.SetLogout();

        AppState.OnChange += StateHasChanged;
    }

    private async Task DownloadPdf()
    {
        await PdfService.DownloadAsync(_username, AppState.Pat);
    }
}
}

<style>
    .page {
        position: relative;
        display: flex;
        flex-direction: column;
    }

    main {
        flex: 1;
    }

    .sidebar {
        background-image: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);
    }

    .top-row {
        background-color: #f7f7f7;
        border-bottom: 1px solid #d6d5d5;
        justify-content: flex-end;
        height: 3.5rem;
        display: flex;
        align-items: center;
    }

        .top-row a, .top-row .btn-link {
            white-space: nowrap;
            margin-left: 1.5rem;
            text-decoration: none;
        }

            .top-row a:hover, .top-row .btn-link:hover {
                text-decoration: underline;
            }

            .top-row a:first-child {
                overflow: hidden;
                text-overflow: ellipsis;
            }

    @@media (max-width: 640.98px) {
        .top-row {
            justify-content: flex-end;
        }

            .top-row a, .top-row .btn-link {
                margin-left: 0;
            }

