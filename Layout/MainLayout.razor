@inherits LayoutComponentBase

<MudThemeProvider />

<MudDialogProvider />

<MudSnackbarProvider />

<MudLayout>


    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">
            GitHub Portfolio
        </MudText>

        <MudSpacer />

        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Home"
                   OnClick="@(() => Nav.NavigateTo("/"))">

            Repositories

        </MudButton>

        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Merge"
                   OnClick="@(() => Nav.NavigateTo("/issues-prs"))">

            PRs & Issues

        </MudButton>
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   Color="Color.Inherit"
                   OnClick="OpenPdfPreview">

            Export PDF

        </MudButton>   
        <MudSpacer />

        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Settings"
                   OnClick="@(() => Nav.NavigateTo("/settings"))">
        </MudButton>

        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="ClearCache">Clear Cache</MudButton>

        @if (!_isLoggedIn)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenLoginDialog">Login</MudButton>
        }
        @if (_isLoggedIn)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Logout">Logout</MudButton>
        }
    </MudAppBar>


    @if (_loginDialogOpen)
    {
        <MudPaper Class="pa-6 mx-auto mt-8" Style="max-width:400px;position:fixed;top:20vh;left:0;right:0;z-index:1300;background:white;box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <MudText Typo="Typo.h6">Enter GitHub PAT</MudText>
            <MudTextField @bind-Value="_pat" Label="Personal Access Token" Variant="Variant.Outlined" InputType="InputType.Password" Class="mt-2 mb-2" />
            <MudButton Variant="Variant.Filled" OnClick="Login" Disabled="string.IsNullOrWhiteSpace(_pat)">Login</MudButton>
            <MudButton Variant="Variant.Text" OnClick="CloseLoginDialog">Cancel</MudButton>
            @if (_loginError != null)
            {
                <MudText Color="Color.Error">@_loginError</MudText>
            }
        </MudPaper>
    }

    <MudMainContent Class="pa-4">

        @Body

    </MudMainContent>


@code {
    private async Task ClearCache()
    {
        await LocalStorage.ClearAsync();
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }
    [Inject] private Portfolio.App.Services.AppState AppState { get; set; } = default!;
    [Inject] private GitHubPdfService PdfService { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private GitHubPdfBuilderService PdfBuilder { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private Blazored.LocalStorage.ILocalStorageService LocalStorage { get; set; } = default!;
    [Inject] private IConfiguration Configuration { get; set; } = default!;

    [Parameter] public EventCallback<bool> OnLoginStateChanged { get; set; }

    private bool _isLoggedIn => AppState.IsLoggedIn;
    private bool _loginDialogOpen = false;
    private string _pat = string.Empty;
    private string? _loginError;
    private string _username = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var stored = await LocalStorage.GetItemAsStringAsync("github_username");
        if (string.IsNullOrWhiteSpace(_username))
        {
            if (!string.IsNullOrWhiteSpace(stored))
                _username = stored;
            else
                _username = Configuration["GitHub:DefaultUsername"] ?? "fauxtix";
        }

    }

    private async Task OpenPdfPreview()
    {
        var pat = AppState.Pat;

        var model = await PdfBuilder.BuildAsync(_username, pat);

        var parameters = new DialogParameters
        {
            ["Model"] = model,
            ["OnExport"] = EventCallback.Factory.Create(this, async () =>
            {
                await PdfService.DownloadAsync(_username, pat);
            })
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Medium,
            Position = DialogPosition.Center
        };

        await DialogService.ShowAsync<PdfExportDialog>(
            "Export Portfolio",
            parameters,
            options);
    }

    private void OpenSettings() => Nav.NavigateTo("/settings");

    private void OpenLoginDialog()
    {
        _loginDialogOpen = true;
        _loginError = null;
    }

    private void CloseLoginDialog()
    {
        _loginDialogOpen = false;
        _pat = string.Empty;
        _loginError = null;
    }


    private async Task Login()
    {
        _loginError = null;
        try
        {
            using var http = new HttpClient();
            http.DefaultRequestHeaders.UserAgent.ParseAdd("PortfolioApp");
            http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("token", _pat);
            var resp = await http.GetAsync("https://api.github.com/user");
            if (!resp.IsSuccessStatusCode)
            {
                _loginError = "Invalid PAT or insufficient permissions.";
                StateHasChanged();
                return;
            }
            await LocalStorage.SetItemAsStringAsync("github_pat", _pat);
            AppState.SetLogin(_pat);
            CloseLoginDialog();
        }
        catch
        {
            _loginError = "Network or API error.";
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("github_pat");
        AppState.SetLogout();
    }

    // Do not restore login state from local storage on app start
    protected override void OnInitialized()
    {
        AppState.SetLogout();
        AppState.OnChange += StateHasChanged;
    }

    private async Task DownloadPdf()
    {
        await PdfService.DownloadAsync(_username, AppState.Pat);
    }
}
</MudLayout>
